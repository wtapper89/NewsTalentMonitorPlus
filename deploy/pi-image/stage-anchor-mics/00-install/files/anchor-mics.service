[Unit]
Description=News Talent Monitor+ FastAPI service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=cci
WorkingDirectory=/opt/anchor-mics
Environment=ANCHOR_MICS_SOURCE=qlxd
Environment=ANCHOR_MICS_HOST=0.0.0.0
Environment=ANCHOR_MICS_PORT=8010
ExecStart=/opt/anchor-mics/.venv/bin/python /opt/anchor-mics/run.py
Restart=always
RestartSec=2
TimeoutStopSec=5

[Install]
WantedBy=multi-user.target
